model Organizer {
  id        String   @id @default(cuid())
  userId    String   @unique // FK to User (each user can have only ONE organizer profile)
  name      String    // Public name/brand
  slug      String   @unique // URL-friendly identifier e.g. "tagdev-events"
  bio       String? // Description
  logoUrl   String? // Logo
  bannerUrl String? // Banner for organizer profile
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id]) //relation to the user table
  events       Event[]                                   // Organizer's events
}
